# Dominio publico que apontara para o servidor.
DOMAIN=previdenciario.seudominio.com.br

# Token simples para proteger a API interna.
# Gere um valor forte antes de publicar: openssl rand -hex 32
INTERNAL_ACCESS_TOKEN=troque-este-token

# Banco PostgreSQL.
POSTGRES_DB=previdenciario
POSTGRES_USER=previdenciario
POSTGRES_PASSWORD=troque-esta-senha
DATABASE_URL=postgresql://previdenciario:troque-esta-senha@db:5432/previdenciario

# URL interna do backend usada pelo Next.js no Docker.
BACKEND_URL=http://backend:8000

# Opcional, para futura redacao assistida por IA.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

NEXT_TELEMETRY_DISABLED=1
